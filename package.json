{
  "name": "anon-conf-poll",
  "version": "0.1.0",
  "description": "Static, anonymous live polling with CRDT sync, zk one-vote proofs, and local analytics.",
  "type": "module",
  "private": false,
  "homepage": "https://baditaflorin.github.io/anon-conf-poll/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/anon-conf-poll.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/anon-conf-poll/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && cp docs/index.html docs/404.html",
    "preview": "vite preview --host 0.0.0.0",
    "pages-preview": "npx http-server docs -p 4174 -c-1",
    "test": "vitest run --coverage=false",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke": "bash scripts/smoke.sh",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.1-dev132.0",
    "@semaphore-protocol/group": "4.12.1",
    "@semaphore-protocol/identity": "4.12.1",
    "@semaphore-protocol/proof": "4.12.1",
    "@tanstack/react-query": "^5.90.12",
    "idb-keyval": "^6.2.2",
    "libsodium-wrappers-sumo": "^0.7.15",
    "lucide-react": "^0.555.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.27",
    "zod": "^4.1.13"
  },
  "overrides": {
    "bfj": "9.1.3",
    "snarkjs": "0.7.6",
    "underscore": "1.13.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22"
  }
}
